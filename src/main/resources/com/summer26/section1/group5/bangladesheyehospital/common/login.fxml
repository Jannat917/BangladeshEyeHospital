<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="500.0" prefWidth="700.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.summer26.section1.group5.bangladesheyehospital.common.LoginController">

    <children>

        <Label layoutX="175.0" layoutY="40.0" text="Bangladesh Eye Hospital">
            <font>
                <Font size="28.0" />
            </font>
        </Label>

        <Label layoutX="295.0" layoutY="90.0" text="Login">
            <font>
                <Font size="20.0" />
            </font>
        </Label>

        <Label layoutX="150.0" layoutY="135.0" text="Role" />

        <ComboBox fx:id="roleComboBox" layoutX="250.0" layoutY="130.0" prefWidth="250.0" />

        <Label layoutX="150.0" layoutY="190.0" text="User ID" />

        <TextField fx:id="userIdTextField" layoutX="250.0" layoutY="185.0" prefWidth="250.0" promptText="Enter User ID" />

        <Label layoutX="150.0" layoutY="245.0" text="Password" />

        <PasswordField fx:id="passwordTextField" layoutX="250.0" layoutY="240.0" prefWidth="250.0" promptText="Enter Password" />

        <Button layoutX="250.0" layoutY="320.0" onAction="#loginButton" prefWidth="110.0" text="Login" />

        <Button layoutX="320.0" layoutY="377.0" onAction="#clearButton" prefWidth="110.0" text="Clear" />

        <Label fx:id="messageLabel" layoutX="180.0" layoutY="390.0" prefWidth="350.0" />
      <Button layoutX="390.0" layoutY="320.0" onAction="#signUpButton" prefWidth="110.0" text="Sign Up" />

    </children>

</AnchorPane>
