<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="658.0" prefWidth="824.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.summer26.section1.group5.bangladesheyehospital.nisa.PatientDashboardcontroller">
   <children>
      <Label fx:id="patientdashboardLabel" layoutX="269.0" layoutY="14.0" prefHeight="65.0" prefWidth="299.0" text="Patient Dashboard">
         <font>
            <Font size="36.0" />
         </font>
      </Label>
      <VBox layoutX="298.0" layoutY="170.0" prefHeight="234.0" prefWidth="178.0">
         <children>
            <Button mnemonicParsing="false" onAction="#bookappointmentOnAction" prefHeight="27.0" prefWidth="179.0" text="Book Appointment">
               <font>
                  <Font size="13.0" />
               </font>
            </Button>
            <Button mnemonicParsing="false" onAction="#doctorscheduleOnAction" prefHeight="27.0" prefWidth="278.0" text="Doctor Schedule">
               <font>
                  <Font size="13.0" />
               </font>
            </Button>
            <Button mnemonicParsing="false" onAction="#prescriptionOnAction" prefHeight="27.0" prefWidth="180.0" text="Prescription">
               <font>
                  <Font size="13.0" />
               </font>
            </Button>
            <Button mnemonicParsing="false" onAction="#payhospitalbillOnAction" prefHeight="26.0" prefWidth="181.0" text="Pay Hospital Bill">
               <font>
                  <Font size="13.0" />
               </font>
            </Button>
            <Button mnemonicParsing="false" onAction="#emergencyappointmentOnAction" prefHeight="26.0" prefWidth="251.0" text="Emergency Appointment">
               <font>
                  <Font size="13.0" />
               </font>
            </Button>
            <Button mnemonicParsing="false" onAction="#updateprofileOnAction" prefHeight="26.0" prefWidth="181.0" text="Update Profile">
               <font>
                  <Font size="13.0" />
               </font>
            </Button>
            <Button mnemonicParsing="false" onAction="#cancelappointmentOnAction" prefHeight="26.0" prefWidth="190.0" text="Cancel Appointment">
               <font>
                  <Font size="13.0" />
               </font>
            </Button>
            <Button mnemonicParsing="false" onAction="#givefeedbackOnAction" prefHeight="26.0" prefWidth="198.0" text="Give Feedback">
               <font>
                  <Font size="13.0" />
               </font>
            </Button>
         </children>
      </VBox>
      <Label fx:id="welcomepatientLabel" layoutX="306.0" layoutY="90.0" prefHeight="58.0" prefWidth="211.0" text="Welcome Patient">
         <font>
            <Font size="18.0" />
         </font>
      </Label>
   </children>
</AnchorPane>
