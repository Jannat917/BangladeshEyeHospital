<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="520.0" prefWidth="700.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.summer26.section1.group5.bangladesheyehospital.common.SignUpController">

    <children>

        <Label layoutX="170.0" layoutY="35.0" text="Bangladesh Eye Hospital">
            <font>
                <Font size="28.0" />
            </font>
        </Label>

        <Label layoutX="295.0" layoutY="85.0" text="Sign Up">
            <font>
                <Font size="20.0" />
            </font>
        </Label>

        <Label layoutX="150.0" layoutY="145.0" text="User ID" />

        <TextField fx:id="userIdTextField" layoutX="280.0" layoutY="140.0" prefWidth="220.0" promptText="Enter User ID" />

        <Label layoutX="150.0" layoutY="195.0" text="Name" />

        <TextField fx:id="nameTextField" layoutX="280.0" layoutY="190.0" prefWidth="220.0" promptText="Enter Name" />

        <Label layoutX="150.0" layoutY="245.0" text="Role" />

        <ComboBox fx:id="roleComboBox" layoutX="280.0" layoutY="240.0" prefWidth="220.0" />

        <Label layoutX="150.0" layoutY="295.0" text="Password" />

        <PasswordField fx:id="passwordField" layoutX="280.0" layoutY="290.0" prefWidth="220.0" promptText="Enter Password" />

        <Button layoutX="220.0" layoutY="380.0" onAction="#registerButton" prefHeight="35.0" prefWidth="110.0" text="Register" />

        <Button layoutX="370.0" layoutY="380.0" onAction="#backButton" prefHeight="35.0" prefWidth="110.0" text="Back" />


        <Label fx:id="messageLabel" layoutX="180.0" layoutY="450.0" prefHeight="30.0" prefWidth="350.0" />

    </children>

</AnchorPane>
